{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-sdk",
    "rootDir": "./src",
    "emitDeclarationOnly": true,
    "declaration": true,
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src/sdk/**/*", "src/api/**/*", "src/types/**/*", "src/layers/**/*"],
  "exclude": ["**/*.test.*", "**/*.spec.*"]
}
