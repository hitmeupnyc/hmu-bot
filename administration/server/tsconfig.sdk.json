{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-sdk",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler"
  },
  "include": ["src/sdk/**/*", "src/api/**/*", "src/types/**/*"],
  "exclude": ["**/*.test.*", "**/*.spec.*"]
}
